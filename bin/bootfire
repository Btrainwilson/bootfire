#!/bin/sh
# bootfire-core: POSIX sh entry point. Walks configured roots, hands the
# candidate list to fzf, and prints the selected path. Never cd's —
# that's the shell wrapper's job.

set -eu

NAME="bootfire"
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}/$NAME"
CONFIG_FILE="$CONFIG_HOME/config"
IGNORE_FILE="$CONFIG_HOME/ignore"

ensure_config_dir() {
    mkdir -p "$CONFIG_HOME"
}

require() {
    command -v "$1" >/dev/null 2>&1 || {
        printf '%s: missing dependency: %s\n' "$NAME" "$1" >&2
        printf 'Install it and re-run, or rerun the bootfire installer.\n' >&2
        exit 127
    }
}

expand_tilde() {
    case "$1" in
        '~')   printf '%s\n' "$HOME" ;;
        '~/'*) printf '%s\n' "$HOME/${1#"~/"}" ;;
        *)     printf '%s\n' "$1" ;;
    esac
}

get_setting() {
    key="$1"; default="$2"
    [ -f "$CONFIG_FILE" ] || { printf '%s\n' "$default"; return; }
    val="$(awk -F= -v k="$key" '$1 == k { print $2; exit }' "$CONFIG_FILE")"
    printf '%s\n' "${val:-$default}"
}

get_roots() {
    [ -f "$CONFIG_FILE" ] || return 0
    awk -F= '/^root=/ { sub(/^root=/, ""); print }' "$CONFIG_FILE" |
        while IFS= read -r r; do
            [ -n "$r" ] && expand_tilde "$r"
        done
}

cmd_help() {
    cat <<EOF
$NAME — fuzzy-find a project directory and run its start.sh

Usage:
  $NAME                   fuzzy-find and deploy
  $NAME -c, --cd-only     fuzzy-find and cd only (skip start.sh)
  $NAME add <path>        add a project root to the config
  $NAME rm <path>         remove a project root from the config
  $NAME list              list configured roots
  $NAME --edit            open the config in \$EDITOR
  $NAME -h, --help        show this help

Config: $CONFIG_FILE
Ignore: $IGNORE_FILE
EOF
}

cmd_add() {
    [ $# -ge 1 ] || { printf 'usage: %s add <path>\n' "$NAME" >&2; exit 2; }
    raw="$1"
    expanded="$(expand_tilde "$raw")"
    target="$(cd "$expanded" 2>/dev/null && pwd)" || {
        printf '%s: not a directory: %s\n' "$NAME" "$raw" >&2
        exit 1
    }
    ensure_config_dir
    [ -f "$CONFIG_FILE" ] || : > "$CONFIG_FILE"
    if grep -Fxq "root=$target" "$CONFIG_FILE"; then
        printf '%s: already a root: %s\n' "$NAME" "$target"
        return 0
    fi
    printf 'root=%s\n' "$target" >> "$CONFIG_FILE"
    printf 'added root: %s\n' "$target"
}

cmd_rm() {
    [ $# -ge 1 ] || { printf 'usage: %s rm <path>\n' "$NAME" >&2; exit 2; }
    raw="$1"
    expanded="$(expand_tilde "$raw")"
    target="$(cd "$expanded" 2>/dev/null && pwd)" || target="$expanded"
    [ -f "$CONFIG_FILE" ] || return 0
    tmp="$(mktemp)"
    grep -Fxv "root=$target" "$CONFIG_FILE" > "$tmp" || true
    mv "$tmp" "$CONFIG_FILE"
    printf 'removed root: %s\n' "$target"
}

cmd_list() {
    get_roots
}

cmd_edit() {
    ensure_config_dir
    [ -f "$CONFIG_FILE" ] || : > "$CONFIG_FILE"
    editor="$(get_setting editor "")"
    [ -n "$editor" ] || editor="${EDITOR:-vi}"
    # shellcheck disable=SC2086
    $editor "$CONFIG_FILE"
}

cmd_select() {
    require fd
    require fzf

    [ -f "$CONFIG_FILE" ] || {
        printf '%s: no config at %s\n' "$NAME" "$CONFIG_FILE" >&2
        printf 'Run `%s add <path>` to add a project root.\n' "$NAME" >&2
        exit 1
    }
    ensure_config_dir

    max_depth="$(get_setting max_depth 4)"

    roots_tmp="$(mktemp)"
    candidates="$(mktemp)"
    trap 'rm -f "$roots_tmp" "$candidates"' EXIT

    get_roots > "$roots_tmp"
    if [ ! -s "$roots_tmp" ]; then
        printf '%s: no roots configured. Run `%s add <path>`.\n' "$NAME" "$NAME" >&2
        exit 1
    fi

    fd_args="--type d --hidden --max-depth $max_depth"
    if [ -f "$IGNORE_FILE" ]; then
        fd_args="$fd_args --ignore-file $IGNORE_FILE"
    fi

    while IFS= read -r root; do
        [ -d "$root" ] || continue
        root="${root%/}"
        printf '%s\n' "$root" >> "$candidates"
        # shellcheck disable=SC2086
        fd $fd_args . "$root" 2>/dev/null | sed 's|/$||' >> "$candidates" || true
    done < "$roots_tmp"

    if [ ! -s "$candidates" ]; then
        printf '%s: no directories found under configured roots.\n' "$NAME" >&2
        exit 1
    fi

    deduped="$(mktemp)"
    awk '!seen[$0]++' "$candidates" > "$deduped"

    if [ "${BOOTFIRE_PRINT_CANDIDATES:-0}" = "1" ]; then
        cat "$deduped"
        rm -f "$deduped"
        return 0
    fi

    fzf --prompt='deploy> ' --height=40% --reverse "$@" < "$deduped" || true
    rm -f "$deduped"
}

ensure_config_dir

case "${1:-}" in
    -h|--help)   cmd_help; exit 0 ;;
    add)         shift; cmd_add "$@"; exit 0 ;;
    rm)          shift; cmd_rm "$@"; exit 0 ;;
    list)        cmd_list; exit 0 ;;
    --edit)      cmd_edit; exit 0 ;;
    *)           cmd_select "$@" ;;
esac
